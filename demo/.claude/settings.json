{
  "permissions": {
    "allow": [
      "Bash(npm run validate)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run format:check)",
      "Bash(npm run format:write)",
      "Bash(npm run auth:setup)",
      "Bash(npm run auth:setup -- --profile *)",
      "Bash(npx playwright test *)",
      "Bash(npx playwright show-report)",
      "Bash(cat test-data/cases/*.json)",
      "Bash(ls src/**)",
      "Bash(ls tests/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(npm publish *)",
      "Bash(cat .env)",
      "Bash(cat .auth/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck 2>&1 | tail -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] Running: $BASH_COMMAND'"
          }
        ]
      }
    ]
  }
}
