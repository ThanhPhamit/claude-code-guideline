    "_comment_cicd": "=== 4. CI/CD ===",

    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-github-pat>"
      }
    },
    "gitlab": {
      "type": "http",
      "url": "https://gitlab.com/api/v4/mcp"
    },
    "jenkins": {
      "type": "http",
      "url": "http://<jenkins-host>/mcp-server/mcp",
      "headers": {
        "Authorization": "Basic <base64-of-user:api-token>"
      }
    },

    "_comment_monitoring": "=== 5. Monitoring ===",

    "grafana": {
      "command": "npx",
      "args": ["-y", "@grafana/mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://localhost:3000",
        "GRAFANA_TOKEN": "<your-grafana-api-token>"
      }
    },

    "_comment_config": "=== 6. Configuration Management ===",

    "ansible": {
      "command": "npx",
      "args": ["-y", "@ansible/aap-mcp-server"],
      "env": {
